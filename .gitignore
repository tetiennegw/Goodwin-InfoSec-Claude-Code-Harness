# ============================================================
# {{harness.name}} — Public Template .gitignore
# Generated by Phase 4 R2 (skeleton build) for the Goodwin
# InfoSec public template fork. Per-user state stays local.
# ============================================================

# Secrets and credentials
.env
.env.*
*.pem
*.key
*.pfx
credentials.json
secrets.json
**/credentials/
**/secrets/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Node
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Claude Code per-user settings (env vars, absolute paths, secrets)
.claude/settings.local.json

# /onboard sentinel — per-user state, not shared
# (Each fork should retain its own onboarding history; commit-cross-contamination
# would force every clone to re-onboard against the wrong identity.)
.harness-onboarded

# Per-user memory store — auto-memory subsystem owns this
memory/

# Per-user daily/weekly/monthly/quarterly/yearly notes
# (The canonical upstream Goodwin source repo demonstrates this; each fork's notes are personal.)
notes/

# Ingest drop zone — personal files being processed
ingest/

# Per-task workspaces — created on demand by /the-protocol Step 7
hub/staging/

# Auto-generated cross-session task views (regenerated from STATE.md)
hub/state/active-tasks.md
hub/state/completed-tasks.md

# Planner runtime state — Goodwin tenant data when Planner extension is enabled
hub/state/planner-pull-cache.json
hub/state/planner-push-queue.json
hub/state/planner-dashboard-data.json
hub/state/planner-mapping.json
hub/state/planner-ids.json
hub/state/.planner-state-snapshots/
hub/state/daily-note-snapshots/
hub/state/ingest-hashes.log

# Operational workspace — incidents, runbooks, brand assets
ops/incidents/
ops/brand/

# Backup files
*.bak

# Keep these directories tracked even when empty
!hub/staging/.gitkeep
!hub/state/.gitkeep
!notes/.gitkeep
!ingest/.gitkeep
!memory/.gitkeep
